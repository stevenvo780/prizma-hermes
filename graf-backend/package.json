{
  "name": "hermes-api",
  "version": "0.0.1",
  "description": "Proyecto de backend para el e-commerce Hermes",
  "author": {
    "name": "Steven Vallejo Ortiz",
    "email": "stevenvallejo780@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stevenvo780/total-pedidos-api.git"
  },
  "private": false,
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "build:prod": "npm run prebuild && nest build --webpack --webpackPath webpack.config.js",
    "build:migrations": "tsc -p tsconfig.migrations.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "seed:dist": "ts-node -r tsconfig-paths/register src/distribution/seed.ts",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "pretest:cov": "node scripts/strip-console-ninja.js",
    "test:cov": "jest --coverage",
    "pretest:cov:html": "node scripts/strip-console-ninja.js",
    "test:cov:html": "jest --coverage --coverageReporters=html && open coverage/index.html || xdg-open coverage/index.html",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:unit": "jest --testPathIgnorePatterns=.*\\.e2e-spec\\.ts$",
    "test:integration": "jest --testPathPattern=.*\\.e2e-spec\\.ts$",
    "pretest:ci": "node scripts/strip-console-ninja.js",
    "test:ci": "jest --coverage --watchAll=false --passWithNoTests",
    "pretest:ci-strict": "node scripts/strip-console-ninja.js",
    "test:ci-strict": "jest --coverage --ci --detectOpenHandles --forceExit",
    "test:clear": "jest --clearCache",
    "docs": "typedoc --options typedoc.json",
    "migration:generate": "node scripts/orm-cli.js generate",
    "migration:validate": "node scripts/orm-cli.js validate",
    "migration:create": "npx typeorm-ts-node-commonjs migration:create",
    "migration:run": "node scripts/orm-cli.js run",
    "migration:revert": "node scripts/orm-cli.js revert",
    "start:prod:safe": "npm run start:prod",
    "start:prod:migrate": "npm run -s migration:run:prod && npm run start:prod"
  },
  "dependencies": {
    "@nestjs/axios": "^4.0.0",
    "@nestjs/common": "^10.0.0",
    "@nestjs/config": "^3.0.0",
    "@nestjs/core": "^10.0.0",
    "@nestjs/jwt": "^10.1.0",
    "@nestjs/mapped-types": "*",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.0.0",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/typeorm": "^10.0.0",
    "@types/compression": "^1.7.5",
    "@types/sanitize-html": "^2.16.0",
    "@types/xlsx": "^0.0.35",
    "axios": "^1.7.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.7.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.4.7",
    "firebase-admin": "^12.3.1",
    "pg": "^8.11.1",
    "prizma-contracts": "^1.3.0",
    "prizma-payments": "^1.0.1",
    "rimraf": "^5.0.10",
    "sanitize-html": "^2.17.0",
    "swagger-ui-express": "^5.0.0",
    "tsconfig-paths": "^4.2.0",
    "typeorm": "^0.3.17",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.0.0",
    "@nestjs/schematics": "^10.0.0",
    "@nestjs/testing": "^10.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^20.3.1",
    "@types/supertest": "^2.0.12",
    "@types/swagger-ui-express": "^4.1.7",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^8.8.0",
    "eslint-plugin-prettier": "^4.2.1",
    "jest": "^29.5.0",
    "pg-mem": "^3.0.5",
    "prettier": "^2.8.8",
    "source-map-support": "^0.5.21",
    "sqlite3": "^5.1.7",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "typedoc": "^0.28.15",
    "typescript": "^5.1.3",
    "webpack": "^5.107.2",
    "webpack-node-externals": "^3.0.0"
  }
}
